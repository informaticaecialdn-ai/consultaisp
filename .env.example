# Required
DATABASE_URL=postgresql://consulta:YOUR_PASSWORD@postgres:5432/consultaisp
DB_PASSWORD=YOUR_SECURE_PASSWORD
SESSION_SECRET=YOUR_RANDOM_SECRET

# Optional
PORT=5000
LOG_LEVEL=info

# LGPD — Hash de CPF/endereco para rede colaborativa
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICO: NUNCA altere este valor apos entrar em producao.
NETWORK_CPF_SALT=

# External services (required for full functionality)
RESEND_API_KEY=
ASAAS_API_KEY=
# Token de autenticacao do webhook Asaas (copie do painel Asaas > Configuracoes > Integracoes > Webhooks)
ASAAS_WEBHOOK_TOKEN=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
GOOGLE_MAPS_API_KEY=

# Superadmin seed
SUPERADMIN_EMAIL=master@consultaisp.com.br
SUPERADMIN_PASSWORD=

# SPC Integration — MMA Web Service SPC BA (set to 'true' when real SPC API is configured)
SPC_API_ENABLED=false
SPC_API_URL=https://webservice.mma.com.br/sivng/webservice/ws_spc.php
SPC_API_TOKEN=
SPC_PRODUCT_CODE=

# LGPD — Email do administrador para alertas de prazo SLA
LGPD_ADMIN_EMAIL=

# Demo data (set to 'true' only in development)
# IMPORTANTE: NODE_ENV=production bloqueia o seed independentemente deste valor.
SEED_DEMO_DATA=false
