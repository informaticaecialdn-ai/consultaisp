# ===== Z-API (WhatsApp) =====
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_TOKEN=seu-token
ZAPI_CLIENT_TOKEN=seu-client-token
ZAPI_BASE_URL=https://api.z-api.io

# ===== SERVER =====
PORT=3001
NODE_ENV=production
# Webhook — Z-API envia mensagens recebidas para esta URL
# Teste local com ngrok: https://abc123.ngrok.io/webhook/zapi
# Producao: https://agentes.consultaisp.com.br/webhook/zapi
WEBHOOK_URL=https://seu-dominio.com/webhook/zapi

# ===== META ADS (Facebook/Instagram) =====
META_APP_ID=seu-app-id
META_APP_SECRET=seu-app-secret
META_ACCESS_TOKEN=seu-access-token-longa-duracao
META_AD_ACCOUNT_ID=act_XXXXXXX
META_PIXEL_ID=seu-pixel-id
META_PAGE_ID=seu-page-id

# ===== GOOGLE ADS =====
GOOGLE_ADS_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=seu-client-secret
GOOGLE_ADS_REFRESH_TOKEN=seu-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=seu-developer-token
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_TARGET_CPA_MICROS=50000000

# ===== METAS DE OTIMIZACAO ADS =====
ADS_CPL_META_TARGET=50
ADS_CPA_GOOGLE_TARGET=60

# ===== SUPABASE (opcional - para sincronizar com Consulta ISP) =====
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave

# ===== BROADCAST ENGINE (Sprint 5) =====
# Liga/desliga worker de broadcast (kill switch)
BROADCAST_WORKER_ENABLED=true
# Liga/desliga worker de followup no processo separado (src/worker.js)
FOLLOWUP_WORKER_ENABLED=true
# Executar workers embarcados no HTTP (dev only — producao usa container worker)
RUN_WORKERS_IN_SERVER=false
# Porta do health endpoint interno do worker
WORKER_HEALTH_PORT=9091
# Rate limit default (pode ser overridden por campanha)
BROADCAST_RATE_PER_MIN=20
BROADCAST_JITTER_MIN_SEC=3
BROADCAST_JITTER_MAX_SEC=8
# Retry: 30s, 2min, 10min = 3 tentativas
BROADCAST_MAX_RETRIES=3
BROADCAST_RETRY_DELAYS_SEC=30,120,600
# Se taxa de falha > threshold%, campanha auto-pausa
BROADCAST_FAILURE_THRESHOLD_PCT=20
# Batch de claim do worker
BROADCAST_BATCH_SIZE=10
# Webhook opcional para alertas (Discord/Slack)
# ERROR_REPORT_WEBHOOK=https://discord.com/api/webhooks/.../

# ===== BROADCAST ADMIN / SMOKE (Sprint 5 / T5) =====
# Caminho alternativo para o arquivo .env modificado pelos endpoints
# /api/admin/kill-broadcast e /resume-broadcast (util para testes).
# Deixe vazio em producao — defaults para agentes-sistema/.env
# ENV_FILE_PATH=
# Reusa ERROR_REPORT_WEBHOOK acima para alertas de auto-pause / kill-switch.

# ===== SECURITY (Sprint 2 + login Sprint 4) =====
# Token Bearer para API admin (gere com: openssl rand -hex 32)
# Usado tanto em /api/* (Authorization: Bearer) quanto como senha
# de fallback no /api/auth/login se LOGIN_PASSWORD nao estiver setado.
API_AUTH_TOKEN=

# Senha memorivel para o formulario de login (pagina /login.html).
# Se ausente, login usa o proprio API_AUTH_TOKEN como senha (64 chars).
# Recomendado: setar uma frase forte ex: "isp-vendas-2026-S3guR0!"
LOGIN_PASSWORD=

# Token HMAC para validar callbacks Z-API (X-Z-API-Token)
ZAPI_WEBHOOK_TOKEN=
# true = exigir token no webhook; false = log-only (transicao gradual)
ZAPI_WEBHOOK_ENFORCE=false

# ===== COST MONITORING (Sprint 3 / T2) =====
# Threshold diario de custo Claude em USD — ao atingir dispara alerta
COST_ALERT_DAILY_USD=25
# Webhook (Discord/Slack/generico) para alertas de custo
# COST_ALERT_WEBHOOK=https://discord.com/api/webhooks/.../

# ===== APIFY PROSPECCAO (Sprint 7) =====
# Token da API Apify (https://console.apify.com/account/integrations)
# Sem isso, /api/apify/* retorna 503. Login na plataforma + Settings > Integrations.
APIFY_TOKEN=

# ===== RECEITAWS (enriquecimento CNPJ) =====
# Docs: https://developers.receitaws.com.br/
# Opcional: sem token = ~3 req/min (free), com token = tier paga (mais rapido).
# Service aplica throttle 20s entre calls quando sem token; cache 24h por CNPJ.
RECEITAWS_TOKEN=

# ===== AUTONOMIA — TOOL CALLING AGENTS (Milestone 1 / Frente B) =====
# Liga o modo "agentes autonomos com tools" (platform-agent-client.js).
# Quando true, orchestrator usa Messages API com tool_use loop e agentes
# chamam send_whatsapp, check_consent, mark_qualified, handoff_to_agent etc.
# diretamente, em vez do path analyzeAndDecide (JSON). Rollback: set false.
USE_TOOL_CALLING_AGENTS=false

# ===== AUTONOMIA — PROSPECTOR WORKER (Milestone 1 / Frente C) =====
# Liga cron de scraping + validacao autonoma (src/workers/prospector.js).
# Cron padrao: seg/qua/sex 8h scraping, diariamente 9h validacao.
PROSPECTOR_WORKER_ENABLED=false

# ===== AUTONOMIA — OUTBOUND WORKER (Milestone 2 / Frente D) =====
# Liga Carlos SDR autonomo (cron 2h em horario comercial BR).
# Pega leads prospector_auto + status=novo, chama Platform Agent, envia cold.
OUTBOUND_WORKER_ENABLED=false
# Max cold msgs/dia por agente (evita ban Z-API).
OUTBOUND_MAX_COLD_PER_DAY=30

# ===== AUTONOMIA — SUPERVISOR WORKER (Milestone 3 / Frente F) =====
# Liga Diana supervisora (cron 1h em 1h).
SUPERVISOR_WORKER_ENABLED=false

# ===== AUTONOMIA — AUTO-HEALING (Milestone 3 / Frente G) =====
# Auto-pause se custo Claude hoje ultrapassar este teto (USD)
AUTO_PAUSE_COST_USD=50
# Auto-pause se Z-API ficar down por este tempo (minutos)
AUTO_PAUSE_ZAPI_DOWN_MIN=30
# Auto-pause se taxa de erro passar deste %
AUTO_PAUSE_ERROR_RATE_PCT=5
