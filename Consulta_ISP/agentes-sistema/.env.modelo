# ============================================================
#  AGENTES-SISTEMA  |  Arquivo de Configuracao
# ============================================================
#  Copie este arquivo para .env e preencha os valores.
#  Campos marcados [OBRIGATORIO] sao necessarios para o
#  sistema funcionar. Campos [OPCIONAL] ativam recursos extras.
# ============================================================


# ===================== [OBRIGATORIO] ========================
# Sem estas variaveis o sistema NAO inicia ou NAO responde.
# ============================================================

# ----- Claude API -----
# Chave da API Anthropic — todos os agentes dependem disso
ANTHROPIC_API_KEY=sk-ant-COLE-SUA-CHAVE-AQUI

# ----- IDs dos Agentes (Claude Platform) -----
# Cada agente tem um ID unico na plataforma Anthropic.
# Se voce nao usa agentes pre-configurados na plataforma,
# pode deixar os valores exemplo — o sistema usa models direto.
AGENT_SOFIA_ID=agent_011Ca5mPLbzjTfKFnLn3VAkM
AGENT_LEO_ID=agent_011Ca5mcHZYB3Ki3hRphRZVg
AGENT_CARLOS_ID=agent_011Ca5mnFkBMp7ktd2N5c3zN
AGENT_LUCAS_ID=agent_011Ca5n9NNsdPT8D5ttKpd6j
AGENT_RAFAEL_ID=agent_011Ca5nJJ6QSfbx1gLf2ku5N
AGENT_MARCOS_ID=agent_011Ca6D7HRpUqNJeZQFkdV4w
AGENT_DIANA_ID=agent_011Ca7UfoDbwQeSNXpCaoZtK

# ----- Z-API (WhatsApp) -----
# Sem estas credenciais, mensagens WhatsApp nao sao enviadas/recebidas
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_TOKEN=seu-token
ZAPI_CLIENT_TOKEN=seu-client-token
ZAPI_BASE_URL=https://api.z-api.io

# ----- Servidor -----
PORT=3001
NODE_ENV=production

# ----- Webhook -----
# URL publica onde o Z-API envia mensagens recebidas.
# Apos deploy, configure no painel Z-API ou via POST /api/setup-webhook
WEBHOOK_URL=https://seu-dominio.com/webhook/zapi


# ===================== [OPCIONAL] ============================
# Ativam recursos adicionais. O sistema roda sem eles.
# ============================================================

# ----- Email (Resend) -----
# Necessario apenas se for usar envio de email (multi-canal)
RESEND_API_KEY=re_COLE-SUA-CHAVE-AQUI
EMAIL_FROM=vendas@consultaisp.com.br

# ----- Instagram DM (Meta Graph API) -----
# Necessario apenas se for usar Instagram como canal
META_PAGE_ACCESS_TOKEN=EAA-COLE-SEU-TOKEN-AQUI
META_PAGE_ID=123456789
META_WEBHOOK_VERIFY_TOKEN=token-verificacao-webhook-instagram

# ----- Meta Ads (Facebook/Instagram Ads) -----
# Necessario apenas para gerenciamento automatico de anuncios
META_APP_ID=seu-app-id
META_APP_SECRET=seu-app-secret
META_ACCESS_TOKEN=seu-access-token-longa-duracao
META_AD_ACCOUNT_ID=act_XXXXXXX
META_PIXEL_ID=seu-pixel-id

# ----- Google Ads -----
# Necessario apenas para gerenciamento automatico de anuncios Google
GOOGLE_ADS_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=seu-client-secret
GOOGLE_ADS_REFRESH_TOKEN=seu-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=seu-developer-token
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_TARGET_CPA_MICROS=50000000

# ----- Metas de Otimizacao de Ads -----
# Valores padrao de CPL/CPA para auto-otimizacao
ADS_CPL_META_TARGET=50
ADS_CPA_GOOGLE_TARGET=60

# ----- Supabase (sincronizacao com Consulta ISP) -----
# Necessario apenas se quiser sincronizar dados com o CRM principal
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-publica
